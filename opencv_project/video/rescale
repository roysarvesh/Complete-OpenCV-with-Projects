"""
Simple OpenCV script to capture video and rescale frames.
Usage:
  - Run without args to open default camera: python rescale
  - Or pass a video filepath as the first argument.
  - Press 'q' to quit.

This file is intentionally left as a single-file script. It rescales frames
using a scale factor and shows the original and resized frames.
"""
import sys
import cv2


def rescale_frame(frame, scale=0.75):
    """Rescale frame by given scale (float)."""
    if frame is None:
        return None
    width = int(frame.shape[1] * scale)
    height = int(frame.shape[0] * scale)
    return cv2.resize(frame, (width, height), interpolation=cv2.INTER_AREA)


def main():
    src = 0
    if len(sys.argv) > 1:
        src = sys.argv[1]

    cap = cv2.VideoCapture(src)
    if not cap.isOpened():
        print(f"Unable to open video source: {src}")
        return

    scale = 0.5  # change this value to rescale differently

    while True:
        ret, frame = cap.read()
        if not ret:
            break

        resized = rescale_frame(frame, scale)

        cv2.imshow('Original', frame)
        if resized is not None:
            cv2.imshow('Rescaled', resized)

        if cv2.waitKey(1) & 0xFF == ord('q'):
            break

    cap.release()
    cv2.destroyAllWindows()


if __name__ == '__main__':
    main()
